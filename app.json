{
  "expo": {
    "name": "Forge",
    "slug": "forge-trainer",
    "scheme": "forgetrainer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.tategillespie.classicphysique",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "./plugins/withCleanEntitlements"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.tategillespie.classicphysique"
    }
  }
}
