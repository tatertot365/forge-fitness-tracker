{
  "expo": {
    "name": "Forge",
    "slug": "forge-trainer",
    "scheme": "forgetrainer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.tategillespie.classicphysique",
      "supportsTablet": false,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Used to read workout duration, heart rate, and calories after each training session.",
        "NSHealthUpdateUsageDescription": "Not used.",
        "NSCameraUsageDescription": "Used to scan food barcodes to look up nutrition facts."
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-camera",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Used to read workout duration, heart rate, and calories after each training session.",
          "background": false
        }
      ],
      "./plugins/withCleanEntitlements"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.tategillespie.classicphysique"
    }
  }
}
